# Totalum Database Settings
TOTALUM_API_KEY=your_totalum_api_key
TOTALUM_API_URL=https://api.totalum.app/

# Shopify Credentials
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# EsgForge Service API Settings
ESGFORGE_API_KEY=your_esgforge_service_api_key

# Climatiq API (for emissions calculations)
CLIMATIQ_API_KEY=your_climatiq_api_key

# Better Auth Settings
BETTER_AUTH_SECRET=your_better_auth_secret

# App URL (Local / Production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Credentials
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Admin Configuration
ADMIN_EMAILS=admin@example.com
